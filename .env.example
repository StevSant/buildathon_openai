# =============================================================================
# Pulso — environment template. Copy to `.env` (or set in Vercel / Supabase) and
# fill real values. NOTHING is hardcoded in source; every tunable lives here.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Next.js) — exposed to the browser, so anon/public values only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json  # MapLibre style/tiles
NEXT_PUBLIC_DEFAULT_LAT=-1.05458       # Initial map center latitude (venue: PUCE Manabí, Portoviejo)
NEXT_PUBLIC_DEFAULT_LNG=-80.45445      # Initial map center longitude (venue: PUCE Manabí, Portoviejo)
NEXT_PUBLIC_DEFAULT_ZOOM=14            # Initial map zoom
NEXT_PUBLIC_DEFAULT_RADIUS_METERS=3000 # Default nearby-incident search radius
NEXT_PUBLIC_ALERT_SEVERITY_MIN=4       # Personal WhatsApp alert: minimum severity
NEXT_PUBLIC_ALERT_RADIUS_METERS=500    # Personal WhatsApp alert: tighter radius
NEXT_PUBLIC_VENUE_NAME="Cdla. Primero de Mayo"  # Map-header sector label
NEXT_PUBLIC_VENUE_CITY=Portoviejo               # Map-header city label
NEXT_PUBLIC_OPENAI_REALTIME_URL=https://api.openai.com/v1/realtime/calls  # WebRTC SDP endpoint (override for proxies)

# Keep the NEXT_PUBLIC_* block in sync with frontend/.env.local.example (the copy Next reads).

# -----------------------------------------------------------------------------
# Edge Function secrets (server-side only) — never shipped to the browser.
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Supabase runtime and are deliberately not listed here.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional override for the OpenAI REST base
OPENAI_REALTIME_MODEL=gpt-realtime         # Realtime (voice) model id for the "Cerca" agent
OPENAI_VISION_MODEL=gpt-5.6-terra          # Vision model for report analysis (Build Week lineup: sol=frontier / terra=balanced / luna=cheap)
OPENAI_REALTIME_VOICE=marin                # Agent voice
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe  # Input-audio transcription model for the Realtime session

CEDULA_HASH_PEPPER=change-me-long-random-secret  # HMAC pepper for cédula hashing

IDENTITY_VERIFY_API_URL=                   # Optional external cédula provider (blank = algorithmic only)
IDENTITY_VERIFY_API_KEY=                   # API key for the external provider

# Hermes Agent webhook — proximity-dispatcher POSTs alert payloads here.
HERMES_WEBHOOK_URL=http://<hermes-vm-host>:8644/webhooks/pulso-alerts
HERMES_WEBHOOK_SECRET=your-hermes-webhook-secret   # HMAC V2 signing secret
PROXIMITY_WEBHOOK_SECRET=change-me-random-secret   # Supabase DB webhook guard

# Query / domain bounds
MAX_RADIUS_METERS=10000        # Hard cap on the radius the voice agent can query (agent-tools)
DEFAULT_RADIUS_METERS=3000     # Server-side default search radius (agent-tools)
INCIDENT_TTL_HOURS=24          # Incident TTL for the adapter create() path; direct client inserts use the DB default (24h)
CONFIRM_THRESHOLD=3            # Confirmations needed to mark an incident 'confirmed' (passed to confirm_incident)
DISPUTE_THRESHOLD=3            # Disputes needed to mark an incident 'disputed' (passed to confirm_incident)

# Trust-score weights for core's computeTrustScore helper.
# NOT WIRED YET: nothing recomputes profiles.trust_score today (it stays at its DB default).
TRUST_VERIFIED_BONUS=10        # Points for a verified identity
TRUST_PER_CONFIRMED=2          # Points per confirmed report
TRUST_PER_DISPUTED=3           # Points deducted per disputed report

# Locale
TIMEZONE=America/Guayaquil
DEFAULT_LANGUAGE=es
