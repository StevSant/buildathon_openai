# Hermes Agent secrets for Pulso — deploy to ~/.hermes/.env on the Azure VM.
# Secrets only (API keys, tokens). Everything else goes in config.yaml.
# `hermes config set KEY VALUE` auto-routes API-key-shaped values here.

# ── WhatsApp (Baileys / WhatsApp Web — QR-linked via `hermes whatsapp`) ──────────
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
# Comma-separated numbers (country code, NO "+"). Use the demo phones during judging.
# Set to * to let anyone talk to the bot.
WHATSAPP_ALLOWED_USERS=5939XXXXXXXX
# WHATSAPP_DEBUG=true

# ── Model provider: OpenAI (Buildathon rubric) ──────────────────────────────────
OPENAI_API_KEY=sk-...
# If using the event's OpenAI-compatible gateway (config.yaml provider: custom):
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Pulso tool bridge (VM-side MCP shim → existing agent-tools edge fn) ──────────
# The shim resolves the WhatsApp sender's number → user_id, mints a short-lived
# 'authenticated' Supabase JWT for that user, and calls agent-tools UNCHANGED (backend frozen).
AGENT_TOOLS_URL=https://<project>.functions.supabase.co/agent-tools
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<project service role key — server-only on the VM>
SUPABASE_JWT_SECRET=<project JWT secret — Supabase dashboard → Project Settings → API>

# ── Proactive alerts (outbound) ─────────────────────────────────────────────────
# Shared secret that the Pulso proximity-dispatcher signs its webhook POSTs with, so
# only Pulso can trigger the "pulso-alerts" webhook. Register the webhook on the VM:
#   hermes webhook subscribe "pulso-alerts" \
#     --prompt "Aviso de Pulso para {to}: {kind} — {incident.category} en {incident.area}." \
#     --deliver "whatsapp:{to}" --deliver-only
PULSO_WEBHOOK_SECRET=<shared-secret>
