# ── frontend — client env (NEXT_PUBLIC_* only; safe to expose in the browser) ──
# Copy to .env.local and fill in. Secrets NEVER go here — those are Edge Function secrets.
# Keep in sync with the NEXT_PUBLIC_* block of the root .env.example.

# Supabase project API (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# MapLibre style/tiles URL — needs a full street style at city zoom (the MapLibre demotiles
# style only renders country outlines, which shows as a blank blue map at zoom 14).
# Carto Dark Matter is free, key-less, and matches the dark "navegación nocturna" design.
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Initial map view — venue: PUCE Manabí, Portoviejo, EC (keep in sync with backend/supabase/seed.sql)
NEXT_PUBLIC_DEFAULT_LAT=-1.05458
NEXT_PUBLIC_DEFAULT_LNG=-80.45445
NEXT_PUBLIC_DEFAULT_ZOOM=14

# Map / agent search radius, in meters
NEXT_PUBLIC_DEFAULT_RADIUS_METERS=3000

# Proximity-alert thresholds: a nearby incident escalates to a bottom sheet only when it is
# at least this severe AND closer than this radius; otherwise it is a discreet toast.
NEXT_PUBLIC_ALERT_SEVERITY_MIN=4
NEXT_PUBLIC_ALERT_RADIUS_METERS=500

# "Reenviar código" countdown fallback (seconds). The edge function is authoritative and
# returns the real cooldown; this only seeds the initial UI countdown.
NEXT_PUBLIC_WHATSAPP_RESEND_COOLDOWN_SECONDS=60

# Map-header venue labels (sector + city)
NEXT_PUBLIC_VENUE_NAME="Cdla. Primero de Mayo"
NEXT_PUBLIC_VENUE_CITY=Portoviejo

# OpenAI Realtime WebRTC SDP endpoint (override only when proxying)
NEXT_PUBLIC_OPENAI_REALTIME_URL=https://api.openai.com/v1/realtime/calls

# Report-photo client-side re-encode: longest side in px + JPEG quality (0-1)
NEXT_PUBLIC_PHOTO_MAX_DIMENSION=1600
NEXT_PUBLIC_PHOTO_JPEG_QUALITY=0.85
